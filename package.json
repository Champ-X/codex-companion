{
  "name": "codex-companion",
  "version": "2.1.5",
  "description": "A privacy-first Windows and macOS desktop companion for Codex usage and quota tracking.",
  "main": "src/main.js",
  "author": "Codex Companion contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Champ-X/codex-companion.git"
  },
  "homepage": "https://github.com/Champ-X/codex-companion#readme",
  "bugs": {
    "url": "https://github.com/Champ-X/codex-companion/issues"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "test": "node --test",
    "icon": "electron scripts/generate-icon.js",
    "pack": "electron-builder --dir",
    "pack:win": "electron-builder --dir --win --x64",
    "pack:mac": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir --mac --arm64 --x64",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win nsis --x64",
    "dist:mac": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg --arm64 --x64"
  },
  "devDependencies": {
    "electron": "^40.0.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.codexcompanion.desktop",
    "productName": "Codex Companion",
    "asar": true,
    "files": [
      "src/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "icon": "assets/icon.png",
      "category": "public.app-category.developer-tools",
      "minimumSystemVersion": "12.0",
      "artifactName": "Codex-Companion-${version}-mac-${arch}.${ext}",
      "extendInfo": {
        "LSUIElement": true
      },
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "Codex Companion ${version}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Codex Companion"
    }
  }
}
